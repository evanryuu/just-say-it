# 火山引擎 ARK API Key
# 获取地址: https://console.volcengine.com/ark
ARK_API_KEY=

# ARK API 基础地址 (建议使用你的 curl 验证通过的地址)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型 Endpoint ID (格式如: ep-20241229xxxxxx-xxxxx)
# 或直接用模型名: doubao-pro-32k-240828
ARK_MODEL_ID=

VOLC_TTS_APPID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_RESOURCE_ID=
VOLC_TTS_SPEAKER=

