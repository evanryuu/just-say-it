# 火山引擎 ARK API Key
# 获取地址: https://console.volcengine.com/ark
ARK_API_KEY=

# ARK API 基础地址 (建议使用你的 curl 验证通过的地址)
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 豆包模型 Endpoint ID (格式如: ep-20241229xxxxxx-xxxxx)
# 或直接用模型名: doubao-pro-32k-240828
ARK_MODEL_ID=

# TTS provider selector: "volc" (default) | "minimax"
TTS_PROVIDER=volc

# VolcEngine TTS
VOLC_TTS_APPID=
VOLC_TTS_ACCESS_TOKEN=
VOLC_TTS_RESOURCE_ID=
VOLC_TTS_SPEAKER=
# Speech rate: range varies by model, 0 = normal, positive = faster (try 20–30)
VOLC_TTS_SPEECH_RATE=0

# Minimax TTS (required when TTS_PROVIDER=minimax)
MINIMAX_API_KEY=
MINIMAX_TTS_MODEL=speech-2.8-turbo
MINIMAX_TTS_VOICE_ID=male-qn-qingse
# Optional: happy | sad | angry | fearful | disgusted | surprised | calm | fluent | whisper
MINIMAX_TTS_EMOTION=
# Optional: Chinese | English | Japanese | auto | ...
MINIMAX_TTS_LANGUAGE_BOOST=
MINIMAX_TTS_SAMPLE_RATE=32000
# Speech speed: range [0.5, 2.0], 1.0 = normal (try 1.15–1.25 for Sesame-like pace)
MINIMAX_TTS_SPEED=1.0

